# ─── Auth (wajib untuk login dashboard) ─────────────────────────────────────
AUTH_EMAIL=admin@forextrader.app
AUTH_PASSWORD=forextrader123

# ─── MONEX / MIFX Credentials ────────────────────────────────────────────────
# CATATAN: Credentials broker TIDAK perlu diisi di sini.
# Isi langsung di dashboard → menu Setup → Form API Key MONEX.
# Credentials disimpan di localStorage browser (aman, tidak dikirim ke server selain saat trading).
#
# Jika ingin set via environment (Railway), bisa isi di sini sebagai fallback:
# MONEX_API_KEY=your_api_key
# MONEX_ACCOUNT_ID=your_account_id
# MONEX_API_SECRET=your_secret
# MONEX_ENV=live
# MONEX_BASE_URL=https://api.mifx.com

# ─── Trading Bot Defaults (opsional, override via UI) ───────────────────────
MAX_POSITIONS=1
MAX_RISK_PERCENT=2
STOP_LOSS_PIPS=30
TAKE_PROFIT_PIPS=60
MAX_CONSECUTIVE_LOSSES=3
